const searchBtn = document.getElementById("search-btn");
const playerInput = document.getElementById("player-input");
const playerInfo = document.getElementById("player-info");

searchBtn.addEventListener("click", ()=>{
  const playerName = playerInput.value.trim();
  if(!playerName) return;
  fetchPlayer(playerName);
});

async function fetchPlayer(name){
  // We'll use a free football API (mock example)
  const response = await fetch(`https://api-football-standings.azharimm.site/players/${name}`);
  const data = await response.json();
  displayPlayer(data);
}

function displayPlayer(data){
  if(!data || data.length === 0){
    playerInfo.innerHTML = "<p>Player not found</p>";
    return;
  }

  const player = data[0]; // pick first result
  playerInfo.innerHTML = `
    <div class="player-card">
      <img src="${player.image}" alt="${player.name}">
      <h2>${player.name}</h2>
      <p>Position: ${player.position}</p>
      <p>Team: ${player.team}</p>
      <p>Nationality: ${player.nationality}</p>
      <p>Goals: ${player.goals} | Assists: ${player.assists}</p>
    </div>
  `;
}
